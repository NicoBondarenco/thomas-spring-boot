<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="applicationName" source="spring.thomas.observability.application" defaultValue="unknown-application"/>
    <springProperty scope="context" name="applicationInstance" source="spring.thomas.observability.instance" defaultValue="unknown-instance"/>

    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <includeMdcKeyName>scopeId</includeMdcKeyName>
            <customFields>{"application":"${applicationName}", "instance":"${applicationInstance}"}</customFields>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE_JSON" />
    </root>
</configuration>
